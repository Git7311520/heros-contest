; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are just too many and would
; make this file unreadable by humans.
; See also: https://docs.godotengine.org/en/stable/tutorials/misc/overriding_build_presets.html

config_version=5

[application]
config/name="Heroes Contest"
config/version="0.1.0"
run/main_scene="res://scenes/main.tscn"
config/icon="res://assets/sprites/icon.png"

[display]
window/size/viewport_width=1280
window/size/viewport_height=800
window/stretch/mode="canvas_items"

[rendering]
renderer/rendering_method="canvas_item"
textures/canvas_textures/default_texture_filter=0
